```gitignore
# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------

.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Editors / IDEs
# -----------------------------------------------------------------------------

.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------

*.log
logs/

# -----------------------------------------------------------------------------
# Environment Files
# -----------------------------------------------------------------------------

.env
.env.local
.env.*

!.env.example

compose/.env

# -----------------------------------------------------------------------------
# Generated Dashboards
# -----------------------------------------------------------------------------

compose/grafana/dashboards/*.json

# Keep README if present
!compose/grafana/dashboards/README.md

# -----------------------------------------------------------------------------
# Generated Prometheus Config
# -----------------------------------------------------------------------------

compose/prometheus/prometheus.yml

# -----------------------------------------------------------------------------
# Helm
# -----------------------------------------------------------------------------

*.tgz
charts/*.tgz

# Helm dependency builds
helm/gpulens/charts/

# -----------------------------------------------------------------------------
# Test / Temporary Files
# -----------------------------------------------------------------------------

tmp/
temp/
*.tmp

# -----------------------------------------------------------------------------
# Coverage
# -----------------------------------------------------------------------------

coverage/
.coverage

# -----------------------------------------------------------------------------
# Shell
# -----------------------------------------------------------------------------

*.bak

# -----------------------------------------------------------------------------
# macOS sed backups
# -----------------------------------------------------------------------------

*.json.bak

# -----------------------------------------------------------------------------
# Terraform (if added later)
# -----------------------------------------------------------------------------

.terraform/
*.tfstate
*.tfstate.*

# -----------------------------------------------------------------------------
# Python (future exporters/tools)
# -----------------------------------------------------------------------------

__pycache__/
*.pyc

# -----------------------------------------------------------------------------
# Node.js (future dashboard tooling)
# -----------------------------------------------------------------------------

node_modules/

# -----------------------------------------------------------------------------
# Generated Documentation
# -----------------------------------------------------------------------------

site/
dist/
build/
```
