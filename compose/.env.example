# Copy to .env and edit. These are the knobs that point gpulens at YOUR cluster.

# --- Scrape targets (comma-separated host:port) ---
# Your GPU nodes' DCGM exporters (default DCGM port is 9400):
DCGM_TARGETS="gpu-node-1:9400,gpu-node-2:9400"

# Your SLURM exporter (host:port). Used as a scrape target.
SLURM_EXPORTER_TARGET="controller:8080"

# Optional node-exporter targets (leave empty quotes if unused):
NODE_TARGETS=""

# --- Ports exposed on the host ---
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090


# --- Grafana ---
GRAFANA_ADMIN_PASSWORD="gpulens-changeme"

# --- Only needed if you run the bundled slurm-exporter (--profile slurm) ---
SLURM_CONF_PATH="/etc/slurm"
MUNGE_SOCKET_PATH="/run/munge"
